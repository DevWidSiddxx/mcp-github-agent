# Server Port
PORT=3000

# Security (Set this same secret in your Github Webhook settings if desired)
GITHUB_WEBHOOK_SECRET=my-webhook-secret

# API Keys needed for the Agent
# Github Personal Access token (needs repo access) - Only needed if you want it to create automated PRs
GITHUB_TOKEN=your_github_token_here

# METHOD 1: Discord Webhook (Super easy, no subscriptions or passwords!)
# 1. Create a Discord channel.
# 2. Go to Edit Channel -> Integrations -> Webhooks -> New Webhook
# 3. Copy Webhook URL and paste here.
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR/WEBHOOK/URL

# METHOD 2: Email Notifications (via Nodemailer)
# (e.g., Use Gmail App Passwords if using Gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-google-app-password
EMAIL_RECEIVER=team-lead@gmail.com

# Auto-Updates flag (If true, it tries to PR the codebase if the README is missed)
AUTO_UPDATE_README=false
